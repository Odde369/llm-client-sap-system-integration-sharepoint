Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: LibreChat SAP Integration
Bundle-SymbolicName: com.advades.librechat;singleton:=true
Bundle-Version: 2.0.0.qualifier
Bundle-Activator: com.advades.librechat.Activator
Bundle-Vendor: advades GmbH
Require-Bundle: org.eclipse.ui,
 org.eclipse.core.runtime,
 org.eclipse.core.resources,
 org.eclipse.ui.editors,
 org.eclipse.jface.text,
 org.eclipse.ui.ide
Bundle-RequiredExecutionEnvironment: JavaSE-17
Automatic-Module-Name: com.advades.librechat
Bundle-ActivationPolicy: lazy
Export-Package: com.advades.librechat,
 com.advades.librechat.context,
 com.advades.librechat.browser
